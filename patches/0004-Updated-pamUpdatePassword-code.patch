From ab4220b9f74db8b523ef5aef2e71303326648eeb Mon Sep 17 00:00:00 2001
From: shreyansh-nexthop <shreyansh@nexthop.ai>
Date: Tue, 13 Jan 2026 06:23:41 +0000
Subject: [PATCH 4/5] Updated pamUpdatePassword code

---
 include/pam_authenticate.hpp | 82 +++++++++++++++++++-----------------
 1 file changed, 43 insertions(+), 39 deletions(-)

diff --git a/include/pam_authenticate.hpp b/include/pam_authenticate.hpp
index a9a2ec30..407601c0 100644
--- a/include/pam_authenticate.hpp
+++ b/include/pam_authenticate.hpp
@@ -120,38 +120,34 @@ inline int pamFunctionConversation(int numMsg, const struct pam_message** msgs,
 }
 
 /**
- * @brief Refresh /etc/passwd and /etc/shadow from host namespace.
+ * @brief Sync /etc/passwd, /etc/shadow, /etc/group from /host/etc to container.
  *
- * When bmcweb runs in a container with bind-mounted /etc/passwd and /etc/shadow,
- * changes made on the host (e.g., user creation via sonic-dbus-bridge) may not
- * be visible in the container due to overlayfs copy-on-write behavior.
- * This function uses nsenter to copy fresh copies from the host.
- * Requires container to run with --privileged --pid=host
+ * When bmcweb runs in a container with /etc mounted at /host/etc,
+ * user management operations use --prefix /host or --root /host flags.
+ * After modifications, we need to sync changes back to the container's /etc
+ * so PAM and other operations can see the updated user data.
  */
-inline void refreshHostPasswdFiles()
+inline void syncHostPasswdFiles()
 {
-    // Refresh /etc/passwd from host
-    int ret = std::system(
-        "nsenter -t 1 -m -- cat /etc/passwd > /etc/passwd 2>/dev/null");
+    // Sync /etc/passwd from /host/etc
+    int ret = std::system("cat /host/etc/passwd > /etc/passwd 2>/dev/null");
     if (ret != 0)
     {
-        BMCWEB_LOG_WARNING("Failed to refresh /etc/passwd from host");
+        BMCWEB_LOG_WARNING("Failed to sync /etc/passwd from /host/etc");
     }
 
-    // Refresh /etc/shadow from host
-    ret = std::system(
-        "nsenter -t 1 -m -- cat /etc/shadow > /etc/shadow 2>/dev/null");
+    // Sync /etc/shadow from /host/etc
+    ret = std::system("cat /host/etc/shadow > /etc/shadow 2>/dev/null");
     if (ret != 0)
     {
-        BMCWEB_LOG_WARNING("Failed to refresh /etc/shadow from host");
+        BMCWEB_LOG_WARNING("Failed to sync /etc/shadow from /host/etc");
     }
 
-    // Refresh /etc/group from host (needed for group membership checks)
-    ret = std::system(
-        "nsenter -t 1 -m -- cat /etc/group > /etc/group 2>/dev/null");
+    // Sync /etc/group from /host/etc (needed for group membership checks)
+    ret = std::system("cat /host/etc/group > /etc/group 2>/dev/null");
     if (ret != 0)
     {
-        BMCWEB_LOG_WARNING("Failed to refresh /etc/group from host");
+        BMCWEB_LOG_WARNING("Failed to sync /etc/group from /host/etc");
     }
 }
 
@@ -212,34 +208,42 @@ inline int pamAuthenticateUser(std::string_view username,
 inline int pamUpdatePassword(const std::string& username,
                              const std::string& password)
 {
-    // Use nsenter to run chpasswd in the host namespace.
-    // This is required because bmcweb runs in a container and the bind-mounted
-    // /etc/shadow from host's overlayfs doesn't sync properly when modified.
-    // nsenter -t 1 -m enters the mount namespace of PID 1 (host's init),
-    // allowing chpasswd to modify the host's /etc/shadow directly.
-    // Requires container to run with --privileged --pid=host
-
-    // Build the command: echo "username:password" | chpasswd
-    // We use nsenter to run this in the host's mount namespace
-    std::string cmd = "nsenter -t 1 -m -- /bin/sh -c 'echo \"" + username +
-                      ":" + password + "\" | /usr/sbin/chpasswd'";
-
-    BMCWEB_LOG_DEBUG("Executing password update via nsenter for user: {}",
-                     username);
-
-    int ret = std::system(cmd.c_str());
+    // Use nsenter to run chpasswd in the host's mount namespace.
+    // This ensures PAM modules are available and password is set on host.
+
+    BMCWEB_LOG_DEBUG("Executing password update for user: {}", username);
+
+    // Build command: echo "user:pass" | nsenter -t 1 -m -- chpasswd
+    // We use popen to write password via stdin to avoid shell escaping issues
+    FILE* proc = popen("nsenter -t 1 -m -- chpasswd", "w");
+    if (proc == nullptr)
+    {
+        BMCWEB_LOG_ERROR("Failed to open nsenter/chpasswd process");
+        return PAM_AUTHTOK_ERR;
+    }
+
+    std::string input = username + ":" + password + "\n";
+    size_t written = fwrite(input.c_str(), 1, input.size(), proc);
+    if (written != input.size())
+    {
+        BMCWEB_LOG_ERROR("Failed to write to chpasswd process");
+        pclose(proc);
+        return PAM_AUTHTOK_ERR;
+    }
+
+    int ret = pclose(proc);
     if (ret != 0)
     {
-        BMCWEB_LOG_ERROR("Failed to update password for user: {}, exit code: {}",
+        BMCWEB_LOG_ERROR("chpasswd failed for user: {}, exit code: {}",
                          username, ret);
         return PAM_AUTHTOK_ERR;
     }
 
     BMCWEB_LOG_DEBUG("Password updated successfully for user: {}", username);
 
-    // Refresh passwd/shadow/group files from host after password update
-    // so the container can see the newly created user for subsequent operations
-    refreshHostPasswdFiles();
+    // Sync passwd/shadow/group files from host to container's /etc
+    // so PAM can see the updated password for subsequent authentication
+    syncHostPasswdFiles();
 
     return PAM_SUCCESS;
 }
-- 
