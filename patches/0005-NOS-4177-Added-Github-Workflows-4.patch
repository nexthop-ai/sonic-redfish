diff --git a/.github/workflows/advance-submodule-ref.yml b/.github/workflows/advance-submodule-ref.yml
new file mode 100644
index 00000000..b0099104
--- /dev/null
+++ b/.github/workflows/advance-submodule-ref.yml
@@ -0,0 +1,20 @@
+name: Trigger Superproject Submodule Sync
+
+on:
+  pull_request:
+    branches:
+      - master
+      - '20*'
+    types: [closed]
+
+jobs:
+  sync-nh:
+    if: github.event.pull_request.merged == true
+    uses: nexthop-ai/nh/.github/workflows/update-submodule-pointer.yml@main
+    with:
+      superproject_repo: nexthop-ai/private-sonic-buildimage
+      submodule_repo: ${{ github.repository }}
+      submodule_path: src/bmcweb
+    secrets:
+      GH_TOKEN: ${{ secrets.RABBIT_NEXTHOP_PAT }}
+      GH_TOKEN_PR_APPROVER: ${{ secrets.NEXTHOP_ORG_GHA_PAT }}
