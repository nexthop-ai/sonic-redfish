From defdc89eaf5d44e44312de396251cefab6c6c997 Mon Sep 17 00:00:00 2001
From: shreyansh-nexthop <shreyansh@nexthop.ai>
Date: Tue, 16 Dec 2025 13:46:20 +0530
Subject: [PATCH 2/5] Skip Authorization when calling D-Bus service APIs (#2)

Do only PAM Authentication and skip the authorization (which is done after authentication succeeds)
---
 include/dbus_privileges.hpp | 25 +++++++++++++++----------
 1 file changed, 15 insertions(+), 10 deletions(-)

diff --git a/include/dbus_privileges.hpp b/include/dbus_privileges.hpp
index eb6b13bd..8357b347 100644
--- a/include/dbus_privileges.hpp
+++ b/include/dbus_privileges.hpp
@@ -186,7 +186,8 @@ inline void requestUserInfo(
 
 inline void validatePrivilege(
     const std::shared_ptr<Request>& req,
-    const std::shared_ptr<bmcweb::AsyncResp>& asyncResp, BaseRule& rule,
+    [[maybe_unused]] const std::shared_ptr<bmcweb::AsyncResp>& asyncResp,
+    [[maybe_unused]] BaseRule& rule,
     std::move_only_function<void()>&& callback)
 {
     if (req->session == nullptr)
@@ -194,15 +195,19 @@ inline void validatePrivilege(
         return;
     }
 
-    requestUserInfo(
-        req->session->username, asyncResp,
-        [req, asyncResp, &rule, callback = std::move(callback)](
-            const dbus::utility::DBusPropertiesMap& userInfoMap) mutable {
-            if (afterGetUserInfoValidate(*req, asyncResp, rule, userInfoMap))
-            {
-                callback();
-            }
-        });
+    // SKIP Authorization: Commenting out D-Bus call
+    // requestUserInfo(
+    //     req->session->username, asyncResp,
+    //     [req, asyncResp, &rule, callback = std::move(callback)](
+    //         const dbus::utility::DBusPropertiesMap& userInfoMap) mutable {
+    //         if (afterGetUserInfoValidate(*req, asyncResp, rule, userInfoMap))
+    //         {
+    //             callback();
+    //         }
+    //     });
+
+    // SKIP AUTHORIZATION: Directly execute callback without D-Bus check
+    callback();
 }
 
 inline void getUserInfo(const std::shared_ptr<bmcweb::AsyncResp>& asyncResp,
-- 
