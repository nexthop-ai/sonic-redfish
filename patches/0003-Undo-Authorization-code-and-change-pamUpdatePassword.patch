diff --git a/include/pam_authenticate.hpp b/include/pam_authenticate.hpp
index 06202a33..a9a2ec30 100644
--- a/include/pam_authenticate.hpp
+++ b/include/pam_authenticate.hpp
@@ -9,6 +9,7 @@
 
 #include <algorithm>
 #include <cstddef>
+#include <cstdlib>
 #include <cstring>
 #include <memory>
 #include <optional>
@@ -118,6 +119,42 @@ inline int pamFunctionConversation(int numMsg, const struct pam_message** msgs,
     return PAM_SUCCESS;
 }
 
+/**
+ * @brief Refresh /etc/passwd and /etc/shadow from host namespace.
+ *
+ * When bmcweb runs in a container with bind-mounted /etc/passwd and /etc/shadow,
+ * changes made on the host (e.g., user creation via sonic-dbus-bridge) may not
+ * be visible in the container due to overlayfs copy-on-write behavior.
+ * This function uses nsenter to copy fresh copies from the host.
+ * Requires container to run with --privileged --pid=host
+ */
+inline void refreshHostPasswdFiles()
+{
+    // Refresh /etc/passwd from host
+    int ret = std::system(
+        "nsenter -t 1 -m -- cat /etc/passwd > /etc/passwd 2>/dev/null");
+    if (ret != 0)
+    {
+        BMCWEB_LOG_WARNING("Failed to refresh /etc/passwd from host");
+    }
+
+    // Refresh /etc/shadow from host
+    ret = std::system(
+        "nsenter -t 1 -m -- cat /etc/shadow > /etc/shadow 2>/dev/null");
+    if (ret != 0)
+    {
+        BMCWEB_LOG_WARNING("Failed to refresh /etc/shadow from host");
+    }
+
+    // Refresh /etc/group from host (needed for group membership checks)
+    ret = std::system(
+        "nsenter -t 1 -m -- cat /etc/group > /etc/group 2>/dev/null");
+    if (ret != 0)
+    {
+        BMCWEB_LOG_WARNING("Failed to refresh /etc/group from host");
+    }
+}
+
 /**
  * @brief Attempt username/password authentication via PAM.
  * @param username The provided username aka account name.
@@ -175,34 +212,34 @@ inline int pamAuthenticateUser(std::string_view username,
 inline int pamUpdatePassword(const std::string& username,
                              const std::string& password)
 {
-    PasswordData data;
-    if (int ret = data.addPrompt("New password: ", password);
-        ret != PAM_SUCCESS)
+    // Use nsenter to run chpasswd in the host namespace.
+    // This is required because bmcweb runs in a container and the bind-mounted
+    // /etc/shadow from host's overlayfs doesn't sync properly when modified.
+    // nsenter -t 1 -m enters the mount namespace of PID 1 (host's init),
+    // allowing chpasswd to modify the host's /etc/shadow directly.
+    // Requires container to run with --privileged --pid=host
+
+    // Build the command: echo "username:password" | chpasswd
+    // We use nsenter to run this in the host's mount namespace
+    std::string cmd = "nsenter -t 1 -m -- /bin/sh -c 'echo \"" + username +
+                      ":" + password + "\" | /usr/sbin/chpasswd'";
+
+    BMCWEB_LOG_DEBUG("Executing password update via nsenter for user: {}",
+                     username);
+
+    int ret = std::system(cmd.c_str());
+    if (ret != 0)
     {
-        return ret;
+        BMCWEB_LOG_ERROR("Failed to update password for user: {}, exit code: {}",
+                         username, ret);
+        return PAM_AUTHTOK_ERR;
     }
-    if (int ret = data.addPrompt("Retype new password: ", password);
-        ret != PAM_SUCCESS)
-    {
-        return ret;
-    }
-    const struct pam_conv localConversation = {pamFunctionConversation, &data};
-    pam_handle_t* localAuthHandle = nullptr; // this gets set by pam_start
 
-    int retval = pam_start("webserver", username.c_str(), &localConversation,
-                           &localAuthHandle);
+    BMCWEB_LOG_DEBUG("Password updated successfully for user: {}", username);
 
-    if (retval != PAM_SUCCESS)
-    {
-        return retval;
-    }
+    // Refresh passwd/shadow/group files from host after password update
+    // so the container can see the newly created user for subsequent operations
+    refreshHostPasswdFiles();
 
-    retval = pam_chauthtok(localAuthHandle, PAM_SILENT);
-    if (retval != PAM_SUCCESS)
-    {
-        pam_end(localAuthHandle, PAM_SUCCESS);
-        return retval;
-    }
-
-    return pam_end(localAuthHandle, PAM_SUCCESS);
+    return PAM_SUCCESS;
 }
