{% from "dockers/dockerfile-macros.j2" import install_debian_packages, install_python_wheels, copy_files %}
ARG BASE=docker-config-engine-trixie-{{DOCKER_USERNAME}}:{{DOCKER_USERTAG}}

FROM $BASE AS base

ARG docker_container_name

## Make apt-get non-interactive
ENV DEBIAN_FRONTEND=noninteractive

# Install bmcweb and sonic-dbus-bridge runtime dependencies
# systemd package provides systemd-socket-activate for socket activation inside container
# python3 and iputils-ping are needed for get_switch_hostname.py script (Redfish Product field)
RUN apt-get update      && \
    apt-get install -f -y  \
        libpam0g           \
        libssl3t64         \
        libsystemd0        \
        zlib1g             \
        libnghttp2-14      \
        libtinyxml2-11     \
        libhiredis1.1.0    \
        libjsoncpp26       \
        libboost-system1.83.0 \
        dbus               \
        systemd            \
        python3            \
        iputils-ping       \
    && rm -rf /var/lib/apt/lists/*

{% if docker_bmcweb_debs.strip() -%}
# Copy locally-built Debian package dependencies
{{ copy_files("debs/", docker_bmcweb_debs.split(' '), "/debs/") }}

# Install locally-built Debian packages and implicitly install their dependencies
{{ install_debian_packages(docker_bmcweb_debs.split(' ')) }}
{%- endif %}

# Create necessary directories
RUN mkdir -p /etc/bmcweb && \
    mkdir -p /var/lib/bmcweb && \
    mkdir -p /usr/share/www && \
    mkdir -p /host/etc

COPY ["supervisord.conf", "/etc/supervisor/conf.d/"]
COPY ["critical_processes", "/etc/supervisor/"]
COPY ["start.sh", "/usr/local/bin/"]
RUN chmod +x /usr/local/bin/start.sh

ENTRYPOINT ["/usr/local/bin/start.sh"]
